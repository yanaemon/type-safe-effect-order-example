-// 4) 「実行前に schedule を型で覗く」道具 (inspector 型)
-// -----------------------------------------------------------------------------
-//
-// Steps はタプル型なので、conditional types で自由に操作できる。
-// 例: 「何ステップ?」「最後の Step は?」「save を含むか?」など、
-// すべて compile-time に確定する。
-
-type ScheduleOf<P> = P extends Program<infer _S, infer Steps> ? Steps : never;
-type StepCount<P> = ScheduleOf<P>["length"];
-type LastStep<P> = ScheduleOf<P> extends readonly [...infer _, infer L] ? L : never;
-type IncludesNotify<P> =
-    ScheduleOf<P> extends readonly (infer U)[] ? (NotifyStep extends U ? true : false) : false;
-
-// 動作確認 (compile-time のみ。値レベルでは使われない)
-type _Schedule = ScheduleOf<typeof program>;
-//   ^? readonly [ValidateStep, SaveStep, NotifyStep]
-type _Count = StepCount<typeof program>;
-//   ^? 3
-type _Last = LastStep<typeof program>;
-//   ^? NotifyStep
-type _HasNotify = IncludesNotify<typeof program>;
-//   ^? true
-
-// inspector が嘘をついていないか、AssertEq で固める
-type AssertEq<A, B> = [A] extends [B] ? ([B] extends [A] ? true : false) : false;
-type _Check1 = AssertEq<_Schedule, readonly [ValidateStep, SaveStep, NotifyStep]>;
