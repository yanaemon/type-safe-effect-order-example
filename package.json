{
  "name": "type-safe-effect-order-example",
  "version": "0.1.0",
  "private": true,
  "description": "Example code for TSKaigi 2026: TypeScript の型で副作用の実行順序を制御する",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf compiled",
    "typecheck": "tsc --noEmit",
    "run:01": "tsx src/01-problem.ts",
    "run:02": "tsx src/02-phantom-pipeline.ts",
    "run:03": "tsx src/03-type-state-pattern.ts",
    "run:04": "tsx src/04-type-state-query-builder.ts",
    "run:05": "tsx src/05-runtime-fsm-limitation.ts",
    "run:lib:effect": "tsx src/libraries/effect.ts",
    "diff:01": "diff -u src/01-problem.ts compiled/01-problem.js || true",
    "diff:02": "diff -u src/02-phantom-pipeline.ts compiled/02-phantom-pipeline.js || true",
    "diff:03": "diff -u src/03-type-state-pattern.ts compiled/03-type-state-pattern.js || true"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "effect": "^3.21.2"
  }
}
